<Window x:Class="StroyMaterials.App.Views.OrderEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Заказ"
        Width="820"
        Height="560"
        MinWidth="740"
        MinHeight="520"
        Icon="{DynamicResource AppIcon}">
    <Grid Background="{StaticResource MainBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SecondaryBrush}" Padding="18,0">
            <TextBlock x:Name="TitleTextBlock"
                       VerticalAlignment="Center"
                       FontSize="22"
                       FontWeight="Bold" />
        </Border>

        <Grid Grid.Row="1" Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="90" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Label Content="Артикулы и количество" Style="{StaticResource FieldLabel}" />
            <TextBox x:Name="ItemsTextBox"
                     Grid.Column="1"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     VerticalContentAlignment="Top"
                     Margin="0,0,0,12"
                     ToolTip="Формат: PMEZMH, 2, BPV4MM, 1" />

            <Label Grid.Row="1" Content="Статус заказа" Style="{StaticResource FieldLabel}" />
            <ComboBox x:Name="StatusComboBox"
                      Grid.Row="1"
                      Grid.Column="1"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"
                      Margin="0,0,0,12" />

            <Label Grid.Row="2" Content="Адрес пункта выдачи" Style="{StaticResource FieldLabel}" />
            <ComboBox x:Name="PickupComboBox"
                      Grid.Row="2"
                      Grid.Column="1"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"
                      IsTextSearchEnabled="True"
                      Margin="0,0,0,12" />

            <Grid Grid.Row="3" Grid.ColumnSpan="2" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Label Content="Дата заказа" Style="{StaticResource FieldLabel}" />
                <DatePicker x:Name="OrderDatePicker" Grid.Column="1" />
                <Label Grid.Column="3" Content="Дата выдачи" Style="{StaticResource FieldLabel}" />
                <DatePicker x:Name="DeliveryDatePicker" Grid.Column="4" />
            </Grid>

            <Label Grid.Row="4" Content="Клиент" Style="{StaticResource FieldLabel}" />
            <ComboBox x:Name="CustomerComboBox"
                      Grid.Row="4"
                      Grid.Column="1"
                      IsEditable="True"
                      IsTextSearchEnabled="True"
                      Margin="0,0,0,12" />

            <Label Grid.Row="5" Content="Код получения" Style="{StaticResource FieldLabel}" />
            <TextBox x:Name="ReceiveCodeTextBox"
                     Grid.Row="5"
                     Grid.Column="1"
                     Margin="0,0,0,12" />

            <TextBlock Grid.Row="6"
                       Grid.Column="1"
                       Text="Артикулы вводятся через запятую: артикул, количество, артикул, количество."
                       Foreground="{StaticResource SubtleTextBrush}" />
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource MutedBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,18,0">
                <Button Content="Отмена"
                        Style="{StaticResource SecondaryButton}"
                        MinWidth="110"
                        Margin="0,0,10,0"
                        IsCancel="True" />
                <Button Content="Сохранить"
                        Style="{StaticResource AccentButton}"
                        MinWidth="130"
                        Click="SaveButton_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
