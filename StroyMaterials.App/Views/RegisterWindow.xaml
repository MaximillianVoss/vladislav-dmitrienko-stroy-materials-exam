<Window x:Class="StroyMaterials.App.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ООО &quot;СтройМатериалы&quot; - регистрация"
        Width="620"
        Height="600"
        MinWidth="560"
        MinHeight="560"
        ResizeMode="NoResize"
        Icon="{DynamicResource AppIcon}">
    <Grid Background="{StaticResource MainBrush}">
        <Border MaxWidth="440"
                Padding="30"
                Background="White"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Регистрация клиента"
                           FontSize="26"
                           FontWeight="Bold" />
                <TextBlock Text="Создается учетная запись с ролью «Авторизованный клиент»."
                           Margin="0,8,0,24"
                           FontSize="15"
                           Foreground="{StaticResource SubtleTextBrush}" />

                <Label Content="ФИО" Style="{StaticResource FieldLabel}" />
                <TextBox x:Name="FullNameTextBox"
                         Margin="0,0,0,14"
                         MinWidth="360" />

                <Label Content="Логин" Style="{StaticResource FieldLabel}" />
                <TextBox x:Name="LoginTextBox"
                         Margin="0,0,0,14" />

                <Label Content="Пароль" Style="{StaticResource FieldLabel}" />
                <PasswordBox x:Name="PasswordBox"
                             Margin="0,0,0,14"
                             PasswordChar="●"
                             KeyDown="PasswordBox_KeyDown" />

                <Label Content="Повторите пароль" Style="{StaticResource FieldLabel}" />
                <PasswordBox x:Name="ConfirmPasswordBox"
                             Margin="0,0,0,22"
                             PasswordChar="●"
                             KeyDown="PasswordBox_KeyDown" />

                <Button Content="Создать учетную запись"
                        Style="{StaticResource AccentButton}"
                        Click="RegisterButton_Click" />

                <Button Content="Назад ко входу"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,10,0,0"
                        Click="CancelButton_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
