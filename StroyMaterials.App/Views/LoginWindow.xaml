<Window x:Class="StroyMaterials.App.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ООО &quot;СтройМатериалы&quot; - вход"
        Width="920"
        Height="560"
        MinWidth="820"
        MinHeight="520"
        Icon="{DynamicResource AppIcon}">
    <Grid Background="{StaticResource MainBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="330" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SecondaryBrush}">
            <Grid Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Image x:Name="LogoImage"
                       Width="108"
                       Height="108"
                       HorizontalAlignment="Left"
                       Stretch="Uniform" />

                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <TextBlock Text="ООО &quot;СтройМатериалы&quot;"
                               FontSize="27"
                               FontWeight="Bold"
                               LineHeight="30" />
                    <TextBlock Text="Информационная система учета товаров, заказов и остатков"
                               Margin="0,16,0,0"
                               FontSize="16"
                               LineHeight="21" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="Демонстрационный экзамен 09.02.07"
                           FontSize="14"
                           Foreground="#403326" />
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="56,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="1"
                    MaxWidth="420"
                    Padding="28"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8"
                    HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Вход в систему"
                               FontSize="26"
                               FontWeight="Bold" />
                    <TextBlock Text="Введите учетные данные из базы или продолжите как гость."
                               Margin="0,8,0,24"
                               FontSize="15"
                               Foreground="{StaticResource SubtleTextBrush}" />

                    <Label Content="Логин" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="LoginTextBox"
                             Margin="0,0,0,14"
                             MinWidth="340"
                             Text="" />

                    <Label Content="Пароль" Style="{StaticResource FieldLabel}" />
                    <PasswordBox x:Name="PasswordBox"
                                 Margin="0,0,0,20"
                                 PasswordChar="●"
                                 KeyDown="PasswordBox_KeyDown" />

                    <Button Content="Войти"
                            Style="{StaticResource AccentButton}"
                            Click="LoginButton_Click" />

                    <Button Content="Продолжить как гость"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,10,0,0"
                            Click="GuestButton_Click" />

                    <Border x:Name="DebugAccountsPanel"
                            Visibility="Collapsed"
                            Margin="0,22,0,0"
                            Padding="14"
                            Background="{StaticResource MutedBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="Debug-вход"
                                       FontWeight="SemiBold"
                                       FontSize="15" />
                            <TextBlock Text="Нажмите учетную запись для быстрого входа."
                                       Margin="0,3,0,10"
                                       FontSize="13"
                                       Foreground="{StaticResource SubtleTextBrush}" />
                            <ScrollViewer MaxHeight="250" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="DebugAccountsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource SecondaryButton}"
                                                    Tag="{Binding}"
                                                    Margin="0,0,0,7"
                                                    Padding="10,7"
                                                    HorizontalContentAlignment="Stretch"
                                                    Click="DebugAccountButton_Click">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding FullName}"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Login}"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource SubtleTextBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding RoleName}"
                                                               Margin="12,0,0,0"
                                                               VerticalAlignment="Center"
                                                               FontSize="12"
                                                               Foreground="{StaticResource SubtleTextBrush}" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
