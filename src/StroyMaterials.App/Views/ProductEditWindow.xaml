<Window x:Class="StroyMaterials.App.Views.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар"
        Width="860"
        Height="690"
        MinWidth="780"
        MinHeight="620"
        Icon="{DynamicResource AppIcon}">
    <Grid Background="{StaticResource MainBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SecondaryBrush}" Padding="18,0">
            <TextBlock x:Name="TitleTextBlock"
                       VerticalAlignment="Center"
                       FontSize="22"
                       FontWeight="Bold" />
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="ArticleRow" Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="190" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Label x:Name="ArticleLabel" Content="Артикул" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="ArticleTextBox"
                             Grid.Column="1"
                             IsReadOnly="True"
                             Margin="0,0,0,12" />

                    <Label Grid.Row="1" Content="Наименование" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="NameTextBox"
                             Grid.Row="1"
                             Grid.Column="1"
                             Margin="0,0,0,12" />

                    <Label Grid.Row="2" Content="Категория" Style="{StaticResource FieldLabel}" />
                    <ComboBox x:Name="CategoryComboBox"
                              Grid.Row="2"
                              Grid.Column="1"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              Margin="0,0,0,12" />

                    <Label Grid.Row="3" Content="Описание" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="DescriptionTextBox"
                             Grid.Row="3"
                             Grid.Column="1"
                             MinHeight="88"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top"
                             Margin="0,0,0,12" />

                    <Label Grid.Row="4" Content="Производитель" Style="{StaticResource FieldLabel}" />
                    <ComboBox x:Name="ManufacturerComboBox"
                              Grid.Row="4"
                              Grid.Column="1"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              Margin="0,0,0,12" />

                    <Label Grid.Row="5" Content="Поставщик" Style="{StaticResource FieldLabel}" />
                    <ComboBox x:Name="SupplierComboBox"
                              Grid.Row="5"
                              Grid.Column="1"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              Margin="0,0,0,12" />

                    <Grid Grid.Row="6" Grid.ColumnSpan="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <Label Content="Цена" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="PriceTextBox" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <Label Content="Единица измерения" Style="{StaticResource FieldLabel}" />
                            <ComboBox x:Name="UnitComboBox"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id" />
                        </StackPanel>
                    </Grid>
                </Grid>

                <StackPanel Grid.Column="2">
                    <Label Content="Фото товара" Style="{StaticResource FieldLabel}" />
                    <Border Width="240"
                            Height="160"
                            Background="White"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Image x:Name="ImagePreview"
                               Margin="8"
                               Stretch="Uniform" />
                    </Border>
                    <Button Content="Выбрать фото"
                            Style="{StaticResource AccentButton}"
                            Margin="0,12,0,20"
                            Click="ChooseImageButton_Click" />

                    <Label Content="Количество на складе" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="StockTextBox" Margin="0,0,0,12" />

                    <Label Content="Действующая скидка, %" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="DiscountTextBox" />
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="{StaticResource MutedBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,18,0">
                <Button Content="Отмена"
                        Style="{StaticResource SecondaryButton}"
                        MinWidth="110"
                        Margin="0,0,10,0"
                        IsCancel="True" />
                <Button Content="Сохранить"
                        Style="{StaticResource AccentButton}"
                        MinWidth="130"
                        Click="SaveButton_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
